{
  "source_dir": "taelgar-static",
  "docs_dir": "docs",
  "overrides_source": "taelgar-utils/website/overrides",
  "overrides_dir": "overrides",
  "slugify": true,
  "clean_docs": false,
  "campaigns": ["dufr", "adma"],
  "export_date": "1750-01-01",
  "strip_comments": true,
  "strip_campaign_blocks": true,
  "strip_date_blocks": true,
  "clean_inline_tags": true,
  "home_source": "taelgar-utils/website/templates/home.md",
  "home_dest": "index.md",
  "nav_source": "taelgar-utils/website/templates/toc.md",
  "nav_dest": "toc.md",
  "ignore_file": "ignore_spec.txt",
  "asset_dir": "assets",
  "resize_images": true,
  "resize_exclude_assets": [
    "assets/*map*.png",
    "assets/*map*.jpg",
    "assets/*map*.jpeg",
    "assets/*map*.webp",
    "assets/*fullsize*.png",
    "assets/*fullsize*.jpg",
    "assets/*fullsize*.jpeg",
    "assets/*fullsize*.webp",
    "assets/*region*.png",
    "assets/*region*.jpg",
    "assets/*region*.jpeg",
    "assets/*region*.webp"
  ],
  "max_image_width": 1600,
  "max_image_height": 1600,
  "delete_unlinked_assets": true,
  "base_path": "/taelgarverse/",
  "clean_code_blocks": true,
  "codeblock_template_dir": "taelgar-utils/website/templates",
  "hide_toc_tags": ["person", "item"],
  "hide_nav_tags": [],
  "hide_backlinks_tags": [],
  "unnamed_files": "unlist",
  "stub_files": "skip",
  "skip_future_dated": true,
  "always_include_assets": [],
  "manifest_path": ".website-build/export-manifest.json"
}
